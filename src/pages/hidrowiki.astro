---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hidropoéticas Ambientales: Quebrada Santa Elena como agente de memoria en Wikimedia">
	<main class="min-h-screen">
		<!-- Header -->
		<header class="py-4 md:py-8 px-4 md:px-8">
			<nav class="mb-4 md:mb-8">
				<a href="/" class="inline-flex items-center gap-2 bg-gradient-to-r from-cyan-600/20 to-blue-600/20 hover:from-cyan-500/30 hover:to-blue-500/30 text-cyan-200 hover:text-white px-4 py-2 rounded-lg border border-cyan-500/30 hover:border-cyan-400/50 transition-all duration-300 text-sm md:text-base font-medium backdrop-blur-md shadow-lg hover:shadow-cyan-500/20">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
					</svg>
					Volver al inicio
				</a>
			</nav>
		</header>

		<!-- Main Content -->
		<div class="container mx-auto px-4 max-w-6xl">
			<div class="py-4 px-4 md:px-8">
				<h1 class="text-3xl md:text-4xl font-bold text-center text-white mb-10 text-shadow leading-tight">
					Hidropoéticas Ambientales: Quebrada Santa Elena como agente de memoria en Wikimedia
				</h1>

				<!-- Wikimedia Section -->
				<section class="mb-12">
					<h2 class="text-xl md:text-2xl font-semibold text-cyan-300 mb-4">Página en Wikimedia Colombia</h2>
					<div class="rounded-xl overflow-hidden border border-cyan-500/30 shadow-lg shadow-cyan-900/20">
						<iframe
							src="https://co.wikimedia.org/wiki/Hidropo%C3%A9ticas_Ambientales:_Quebrada_Santa_Elena_como_agente_de_memoria_en_Wikimedia#Contexto_general"
							class="w-full"
							style="height: 80vh; min-height: 500px;"
							title="Hidropoéticas Ambientales en Wikimedia Colombia"
							loading="lazy"
							allow="fullscreen"
						></iframe>
					</div>
					<p class="mt-2 text-center text-sm text-cyan-400/70">
						<a
							href="https://co.wikimedia.org/wiki/Hidropo%C3%A9ticas_Ambientales:_Quebrada_Santa_Elena_como_agente_de_memoria_en_Wikimedia#Contexto_general"
							target="_blank"
							rel="noopener noreferrer"
							class="hover:text-cyan-300 underline underline-offset-2 transition-colors"
						>
							Abrir en Wikimedia Colombia ↗
						</a>
					</p>
				</section>
				<!-- Galería Commons -->
				<section class="mb-12">
					<h2 class="text-xl md:text-2xl font-semibold text-cyan-300 mb-2">Galería — Wikimedia Commons</h2>
					<p class="text-white/50 text-sm mb-6">Imágenes subidas por los participantes del programa durante el proceso.</p>

					<div class="columns-2 sm:columns-3 lg:columns-4 gap-3 space-y-3">

						<a href="https://commons.wikimedia.org/wiki/File:Hidropo%C3%A9ticas_Ambientales.jpg" target="_blank" rel="noopener noreferrer" class="group block break-inside-avoid rounded-xl overflow-hidden border border-cyan-500/20 hover:border-cyan-400/50 transition-all shadow-lg hover:shadow-cyan-900/40">
							<img src="https://upload.wikimedia.org/wikipedia/commons/thumb/4/43/Hidropo%C3%A9ticas_Ambientales.jpg/500px-Hidropo%C3%A9ticas_Ambientales.jpg" alt="Hidropoéticas Ambientales" loading="lazy" class="w-full object-cover group-hover:scale-105 transition-transform duration-300" />
							<div class="bg-black/60 px-3 py-2">
								<p class="text-white/80 text-xs leading-tight">Cascada de la Quebrada Santa Elena. Encuentros Hidropoéticas, 2025.</p>
								<p class="text-cyan-400/60 text-xs mt-1">Sandramirezgiraldo</p>
							</div>
						</a>

						<a href="https://commons.wikimedia.org/wiki/File:Quebrada_Santa_Elena%2C_Medell%C3%ADn_Hidropo%C3%A9ticas_Ambientales_Sandra_Ram%C3%ADrez_Giraldo.jpg" target="_blank" rel="noopener noreferrer" class="group block break-inside-avoid rounded-xl overflow-hidden border border-cyan-500/20 hover:border-cyan-400/50 transition-all shadow-lg hover:shadow-cyan-900/40">
