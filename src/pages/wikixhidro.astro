    let visible = 0;
    rows.forEach(row => {
      const filterMatch =
        activeFilter === 'all' ||
        (activeFilter === 'new' && row.dataset.new === 'true') ||
        row.dataset.project === activeFilter;

      const text = row.textContent?.toLowerCase() ?? '';
      const searchMatch = searchTerm === '' || text.includes(searchTerm);

      const show = filterMatch && searchMatch;
      row.style.display = show ? '' : 'none';
      if (show) visible++;
    });
    if (contador) contador.textContent = `${visible} contribuciones`;
  }

  btns.forEach(btn => {
    btn.addEventListener('click', () => {
      btns.forEach(b => b.classList.remove('active', 'bg-cyan-500/20', 'text-cyan-200', 'border-cyan-500/50'));
      btn.classList.add('active', 'bg-cyan-500/20', 'text-cyan-200', 'border-cyan-500/50');
      activeFilter = btn.dataset.filter ?? 'all';
      applyFilters();
    });
  });

  buscador?.addEventListener('input', () => {
    searchTerm = buscador.value.toLowerCase().trim();
    applyFilters();
  });
</script>
</Layout>
