---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Hidropoéticas Ambientales: Quebrada Santa Elena como agente de memoria en Wikimedia">
	<main class="min-h-screen">
		<!-- Header -->
		<header class="py-4 md:py-8 px-4 md:px-8">
			<nav class="mb-4 md:mb-8">
				<a href="/" class="inline-flex items-center gap-2 bg-gradient-to-r from-cyan-600/20 to-blue-600/20 hover:from-cyan-500/30 hover:to-blue-500/30 text-cyan-200 hover:text-white px-4 py-2 rounded-lg border border-cyan-500/30 hover:border-cyan-400/50 transition-all duration-300 text-sm md:text-base font-medium backdrop-blur-md shadow-lg hover:shadow-cyan-500/20">
					<svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
						<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
					</svg>
					Volver al inicio
				</a>
			</nav>
		</header>

		<!-- Main Content -->
		<div class="container mx-auto px-4 max-w-6xl">
			<div class="py-4 px-4 md:px-8">
				<h1 class="text-3xl md:text-4xl font-bold text-center text-white mb-10 text-shadow leading-tight">
					Hidropoéticas Ambientales: Quebrada Santa Elena como agente de memoria en Wikimedia
				</h1>

				<!-- Wikimedia Section -->
				<section class="mb-12">
					<h2 class="text-xl md:text-2xl font-semibold text-cyan-300 mb-4">Página en Wikimedia Colombia</h2>
					<div class="rounded-xl overflow-hidden border border-cyan-500/30 shadow-lg shadow-cyan-900/20">
						<iframe
							src="https://co.wikimedia.org/wiki/Hidropo%C3%A9ticas_Ambientales:_Quebrada_Santa_Elena_como_agente_de_memoria_en_Wikimedia#Contexto_general"
							class="w-full"
							style="height: 80vh; min-height: 500px;"
							title="Hidropoéticas Ambientales en Wikimedia Colombia"
							loading="lazy"
							allow="fullscreen"
						></iframe>
					</div>
					<p class="mt-2 text-center text-sm text-cyan-400/70">
						<a
							href="https://co.wikimedia.org/wiki/Hidropo%C3%A9ticas_Ambientales:_Quebrada_Santa_Elena_como_agente_de_memoria_en_Wikimedia#Contexto_general"
							target="_blank"
							rel="noopener noreferrer"
							class="hover:text-cyan-300 underline underline-offset-2 transition-colors"
						>
							Abrir en Wikimedia Colombia ↗
						</a>
					</p>
				</section>

				<!-- Contribuciones Section -->
				<section class="mb-12">
					<h2 class="text-xl md:text-2xl font-semibold text-cyan-300 mb-6">Contribuciones de participantes</h2>

					<!-- Buscador -->
					<div class="mb-4">
						<div class="relative">
							<svg xmlns="http://www.w3.org/2000/svg" class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-cyan-400/60 pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor">
								<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
							</svg>
							<input
								id="buscador"
								type="text"
								placeholder="Buscar por título o descripción…"
								class="w-full pl-9 pr-4 py-2 rounded-lg bg-white/5 border border-cyan-500/30 text-white placeholder-cyan-400/40 focus:outline-none focus:border-cyan-400/60 focus:bg-white/10 transition-colors text-sm"
							/>
						</div>
					</div>

					<!-- Filtros -->
					<div class="flex flex-wrap gap-2 mb-6" id="filtros">
						<button data-filter="all"       class="filter-btn active px-4 py-1.5 rounded-full text-sm font-medium border border-cyan-500/50 bg-cyan-500/20 text-cyan-200 hover:bg-cyan-500/30 transition-colors">Todos</button>
						<button data-filter="wikidata"  class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-cyan-500/30 text-cyan-400/70 hover:bg-cyan-500/20 hover:text-cyan-200 transition-colors">Wikidata</button>
						<button data-filter="wikipedia" class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-cyan-500/30 text-cyan-400/70 hover:bg-cyan-500/20 hover:text-cyan-200 transition-colors">Wikipedia</button>
						<button data-filter="new"       class="filter-btn px-4 py-1.5 rounded-full text-sm font-medium border border-green-500/30 text-green-400/70 hover:bg-green-500/20 hover:text-green-200 transition-colors">Nuevos</button>
					</div>

